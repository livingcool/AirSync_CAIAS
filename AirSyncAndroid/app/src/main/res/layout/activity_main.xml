<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Header / Status Area -->
    <LinearLayout
        android:id="@+id/headerArea"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#1E1E1E">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AirSync"
            android:textColor="#BB86FC"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ready for Gesture"
            android:textColor="#E0E0E0"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_below="@id/headerArea"
        android:progressDrawable="@android:color/holo_purple" />

    <!-- Camera / Gesture Visualization Area -->
    <FrameLayout
        android:id="@+id/viewFinderContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/progressBar"
        android:layout_above="@id/bottomControls">

        <androidx.camera.view.PreviewView
            android:id="@+id/viewFinder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:scaleType="fillCenter" />

        <!-- Overlay for Gesture Feedback -->
        <View
            android:id="@+id/gestureOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#40000000"
            android:alpha="0" />
            
        <TextView
            android:id="@+id/gestureLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="32dp"
            android:text="Gesture: --"
            android:textColor="#03DAC6"
            android:textSize="22sp"
            android:textStyle="italic"
            android:padding="12dp"
            android:background="#80000000" />
    </FrameLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="#1E1E1E">

        <Button
            android:id="@+id/btnSelectFile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📁 Browse"
            android:textAllCaps="false"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#3700B3" />

        <Button
            android:id="@+id/btnReceiveMode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📥 Receive"
            android:textAllCaps="false"
            android:backgroundTint="#018786" />
    </LinearLayout>

    <TextView android:id="@+id/ipLabel" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <EditText android:id="@+id/ipInput" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</RelativeLayout>
